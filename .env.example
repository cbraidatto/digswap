# =============================================================================
# DigSwap Environment Variables
# =============================================================================
# Copy to .env.local and fill in values.
# See README.md for setup instructions.
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=                    # Project URL from Supabase dashboard
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=        # anon/public key from Supabase dashboard
# NEXT_PUBLIC_SUPABASE_ANON_KEY=             # Alias for PUBLISHABLE_KEY — set either one
SUPABASE_SERVICE_ROLE_KEY=                   # Service role key (server-side only, never expose to client)
DATABASE_URL=                                # Direct PostgreSQL connection string (for Drizzle)

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # Base URL for server-side redirects and API self-invocation
NEXT_PUBLIC_APP_URL=http://localhost:3000    # Public-facing URL for SEO, sitemap, share links

# --- P2P / WebRTC ---
P2P_ENABLED=true
NEXT_PUBLIC_P2P_ENABLED=true

# --- Stripe ---
STRIPE_SECRET_KEY=                           # Stripe secret key (sk_test_... or sk_live_...)
STRIPE_WEBHOOK_SECRET=                       # Stripe webhook signing secret (whsec_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=          # Stripe publishable key (pk_test_... or pk_live_...)
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=            # Stripe Price ID for monthly plan
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL=             # Stripe Price ID for annual plan

# --- Upstash Redis ---
UPSTASH_REDIS_REST_URL=                      # Upstash Redis REST endpoint
UPSTASH_REDIS_REST_TOKEN=                    # Upstash Redis REST token

# --- Discogs ---
DISCOGS_CONSUMER_KEY=                        # Discogs API consumer key (from developer app)
DISCOGS_CONSUMER_SECRET=                     # Discogs API consumer secret
IMPORT_WORKER_SECRET=                        # Shared secret for import worker internal API auth (generate with: openssl rand -hex 32)

# --- Desktop Handoff ---
HANDOFF_HMAC_SECRET=                         # HMAC-SHA256 signing key for web→desktop handoff tokens (generate with: openssl rand -hex 32)
NEXT_PUBLIC_MIN_DESKTOP_VERSION=1            # Minimum desktop app version required for trade handoff

# --- Email (Resend) ---
RESEND_API_KEY=                              # Resend API key (re_...)
RESEND_FROM_EMAIL=noreply@digswap.com        # Sender address for transactional emails

# --- Community ---
SYSTEM_USER_ID=00000000-0000-0000-0000-000000000000  # UUID for system-created content (genre groups, etc.)

# --- YouTube ---
YOUTUBE_API_KEY=                             # YouTube Data API key (for listening log embeds)

# --- PeerJS signaling server (local dev) ---
NEXT_PUBLIC_PEERJS_HOST=localhost
NEXT_PUBLIC_PEERJS_PORT=9000
NEXT_PUBLIC_PEERJS_PATH=/

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=                      # Sentry DSN for error tracking
SENTRY_ORG=                                  # Sentry organization slug
SENTRY_PROJECT=                              # Sentry project slug
