# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=your_supabase_connection_pooler_url

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=your_stripe_monthly_price_id
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL=your_stripe_annual_price_id

# Sentry
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# Upstash Redis
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Discogs OAuth 1.0a
DISCOGS_CONSUMER_KEY=your_discogs_consumer_key
DISCOGS_CONSUMER_SECRET=your_discogs_consumer_secret

# Import Worker (shared secret for self-invocation auth)
IMPORT_WORKER_SECRET=generate_a_random_32_char_string

# Desktop Handoff (HMAC signing — min 32 chars in production)
HANDOFF_HMAC_SECRET=generate_a_random_32_char_string

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@digswap.com

# Optional
YOUTUBE_API_KEY=
SYSTEM_USER_ID=
NEXT_PUBLIC_MIN_DESKTOP_VERSION=1
