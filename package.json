{
  "name": "digswap-workspace",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": ">=0.25.0"
    },
    "onlyBuiltDependencies": ["ffmpeg-static", "esbuild"]
  },
  "scripts": {
    "dev": "pnpm --filter @digswap/web dev",
    "dev:web": "pnpm --filter @digswap/web dev",
    "dev:desktop": "pnpm --filter @digswap/desktop dev",
    "build": "pnpm --filter @digswap/web build",
    "build:web": "pnpm --filter @digswap/web build",
    "build:desktop": "pnpm --filter @digswap/desktop build",
    "start": "pnpm --filter @digswap/web start",
    "lint": "pnpm -r --if-present lint",
    "lint:web": "pnpm --filter @digswap/web lint",
    "format": "pnpm -r --if-present format",
    "test": "pnpm --filter @digswap/web test",
    "test:e2e": "pnpm --filter @digswap/web test:e2e",
    "typecheck": "pnpm -r --if-present typecheck"
  }
}
