{
  "name": "digswap-workspace",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": ">=0.25.0"
    },
    "onlyBuiltDependencies": ["ffmpeg-static", "esbuild", "better-sqlite3"]
  },
  "scripts": {
    "dev": "pnpm --filter @digswap/web dev",
    "dev:web": "pnpm --filter @digswap/web dev",
    "dev:desktop": "pnpm --filter @digswap/desktop dev",
    "build": "pnpm --filter @digswap/web build",
    "build:web": "pnpm --filter @digswap/web build",
    "build:desktop": "pnpm --filter @digswap/desktop build",
    "start": "pnpm --filter @digswap/web start",
    "lint": "pnpm -r --if-present lint",
    "lint:web": "pnpm --filter @digswap/web lint",
    "format": "pnpm -r --if-present format",
    "test": "pnpm --filter @digswap/web test",
    "test:all": "pnpm -r --if-present test",
    "test:e2e": "pnpm --filter @digswap/web test:e2e",
    "test:coverage": "pnpm --filter @digswap/web test -- --coverage",
    "typecheck": "pnpm -r --if-present typecheck",
    "db:guard": "node scripts/drizzle-prod-guard.mjs",
    "predb:push": "pnpm db:guard",
    "predb:migrate": "pnpm db:guard",
    "db:push": "echo 'drizzle-kit push is invoked from the workspace that owns the schema — this root script exists so the predb:push guard always runs first' && exit 0",
    "db:migrate": "echo 'drizzle-kit migrate is invoked from the workspace that owns the schema — this root script exists so the predb:migrate guard always runs first' && exit 0"
  }
}
